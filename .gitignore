# Python
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.venv/
.python-version.local

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.ipynb_checkpoints/

# Editors / OS
.vscode/
.idea/
*.swp
.DS_Store

# Secrets and local env
.env
.env.*
*.key
*.pem

# Downloaded third-party warm-up text (rebuild with scripts/build_warmup_v1.py;
# the committed .manifest.json pins revisions and hashes)
data/warmup/warmup_v1.jsonl
data/warmup/holdout_v1.jsonl

# Stage 2 offline mixture (rebuild with scripts/build_stage2_v0.py;
# the committed manifest in data/stage2/ pins revisions and hashes)
data/stage2/train/
data/stage2/val/
data/stage2/calib/

# Heavy local artifacts (activation caches, checkpoints, datasets, run outputs)
artifacts/
checkpoints/
datasets/
wandb/
runs/

# Model weights anywhere in the tree (small metadata/manifests stay tracked)
*.safetensors
*.bin
*.gguf
*.pt
*.pth

# Hugging Face / torch caches if ever redirected into the repo
hf_cache/
torch_cache/
